@if (Report is not null)
{
    <div class="mt-3">
        <div class="text-muted small">@Title · @(Report.FinishedUtc?.ToString("yyyy-MM-dd HH:mm:ss") ?? "—")</div>
        <div class="d-flex gap-3 mt-1 mb-2">
            <div><span class="badge bg-secondary">Fetched</span> @Report.Fetched</div>
            <div><span class="badge bg-success">Inserted</span> @Report.Inserted</div>
            <div><span class="badge bg-primary">Updated</span> @Report.Updated</div>
            <div><span class="badge bg-warning text-dark">Skipped</span> @Report.Skipped</div>
            <div><span class="badge bg-danger">Errors</span> @Report.Errors</div>
        </div>
        @if (Report.SkipReasons.Count > 0)
        {
            <details>
                <summary class="text-warning">@Report.SkipReasons.Count skip reason(s)</summary>
                <ul class="small mb-0">
                    @foreach (var r in Report.SkipReasons) { <li>@r</li> }
                </ul>
            </details>
        }
        @if (Report.ErrorMessages.Count > 0)
        {
            <details>
                <summary class="text-danger">@Report.ErrorMessages.Count error(s)</summary>
                <ul class="small mb-0">
                    @foreach (var m in Report.ErrorMessages) { <li>@m</li> }
                </ul>
            </details>
        }
    </div>
}

@code {
    [Parameter, EditorRequired] public SyncReport? Report { get; set; }
    [Parameter, EditorRequired] public string Title { get; set; } = "Sync report";
}
