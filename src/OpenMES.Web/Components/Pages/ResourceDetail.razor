@page "/resources/{Id:int}"
@inject ResourceService Resources
@inject JobService Jobs

<PageTitle>@(_resource?.Code ?? "Resource") — OpenMES</PageTitle>

@if (_resource is null)
{
    <p><em>Loading…</em></p>
}
else
{
    <div class="d-flex align-items-start justify-content-between">
        <div>
            <h1 class="display-6 mb-1">@_resource.Code</h1>
            <div class="text-muted">@_resource.Name · @_resource.ResourceType
                @if (!string.IsNullOrEmpty(_resource.Location)) { <span> · 📍 @_resource.Location</span> }
            </div>
        </div>
        <a class="btn btn-outline-secondary" href="resources">← All resources</a>
    </div>

    <h2 class="h5 mt-4">Jobs at this resource</h2>
    @if (_jobs.Count == 0)
    {
        <p class="text-muted">No jobs assigned.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr><th>Job</th><th>Part / Rev</th><th>Status</th><th class="text-end">Good</th><th class="text-end">Scrap</th><th class="text-end">Ordered</th><th>Due</th><th></th></tr>
                </thead>
                <tbody>
                @foreach (var j in _jobs)
                {
                    <tr>
                        <td class="fw-semibold">@j.JobNumber</td>
                        <td>@(j.PartRevision?.Part?.PartNumber) Rev @(j.PartRevision?.Revision)</td>
                        <td><span class="badge @StatusClass(j.Status)">@j.Status</span></td>
                        <td class="text-end">@j.QuantityGood</td>
                        <td class="text-end">@j.QuantityScrap</td>
                        <td class="text-end">@j.QuantityOrdered</td>
                        <td>@(j.DueUtc?.ToString("yyyy-MM-dd HH:mm") ?? "—")</td>
                        <td><a class="btn btn-sm btn-primary" href="@($"jobs/{j.Id}")">Open</a></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }

    <h2 class="h5 mt-4">Upcoming schedule</h2>
    @if (_schedule.Count == 0)
    {
        <p class="text-muted">Nothing scheduled.</p>
    }
    else
    {
        <ul class="list-group">
            @foreach (var s in _schedule)
            {
                <li class="list-group-item d-flex justify-content-between">
                    <span>
                        <strong>@(s.Job?.JobNumber)</strong>
                        — @(s.Job?.PartRevision?.Part?.PartNumber) Rev @(s.Job?.PartRevision?.Revision)
                    </span>
                    <span class="text-muted small">
                        @s.PlannedStartUtc.ToString("MM-dd HH:mm") → @s.PlannedEndUtc.ToString("MM-dd HH:mm")
                        @if (s.PlannedQuantity is decimal q) { <span> · qty @q</span> }
                    </span>
                </li>
            }
        </ul>
    }
}

@code {
    [Parameter] public int Id { get; set; }
    private Resource? _resource;
    private List<Job> _jobs = new();
    private List<ResourceScheduleEntry> _schedule = new();

    protected override async Task OnInitializedAsync()
    {
        _resource = await Resources.GetAsync(Id);
        if (_resource is not null)
        {
            _jobs = await Jobs.ListForResourceAsync(_resource.Id);
            _schedule = await Resources.GetUpcomingScheduleAsync(_resource.Id, DateTime.UtcNow.AddHours(-2));
        }
    }

    private static string StatusClass(JobStatus s) => s switch
    {
        JobStatus.InProgress => "bg-success",
        JobStatus.Released   => "bg-primary",
        JobStatus.Paused     => "bg-warning text-dark",
        JobStatus.Completed  => "bg-secondary",
        JobStatus.Cancelled  => "bg-dark",
        _                    => "bg-light text-dark"
    };
}
