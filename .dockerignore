# Keep the build context lean. Anything not COPY-ed by the Dockerfile can
# stay out.

# .NET build outputs
**/bin/
**/obj/
**/TestResults/

# IDE / editor crud
**/.vs/
**/.idea/
**/.vscode/
**/*.user
**/*.DotSettings.user

# VCS
.git/
.gitignore
.gitattributes
.github/

# Not needed inside the image
tests/
docs/
samples/
docker-compose.yml
docker-compose.override.yml
Dockerfile
.dockerignore
*.md
LICENSE
CLAUDE.md
prompts.txt

# Local secrets / overrides
**/appsettings.Local.json
**/.env*
